# ---------------------------------------------------------------------------
# Knowledge Assistant configuration. Copy to `.env` and adjust.
# Every variable maps to a field in src/knowledge_assistant/config.py.
# The defaults below match docker-compose.yml — zero changes needed there.
# ---------------------------------------------------------------------------

# Database (async driver)
KA_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/knowledge

# Embeddings — the provider flag drives per-provider defaults (like the LLM).
# With `ollama` (default): nomic-embed-text @ http://localhost:11434 (768 dims).
# With `openai`: text-embedding-3-small @ https://api.openai.com (1536 dims) —
# requires KA_EMBEDDING_API_KEY **and** a new Alembic migration for
# vector(1536) plus SCHEMA_EMBEDDING_DIMENSION in bootstrap.py: the shipped
# schema is vector(768), and any mismatch fails fast at startup (ADR-0001).
KA_EMBEDDING_PROVIDER=ollama            # ollama | openai
# KA_EMBEDDING_MODEL=
# KA_EMBEDDING_BASE_URL=
# KA_EMBEDDING_API_KEY=                 # required when provider=openai
# KA_EMBEDDING_DIMENSION=               # provider default; must match the schema
# KA_EMBEDDING_TIMEOUT_SECONDS=60

# LLM (answer generation) — the provider flag drives per-provider defaults.
# With `ollama` (default): llama3.1 @ http://localhost:11434/v1 (no key needed).
# With `openai`: gpt-4o-mini @ https://api.openai.com/v1 (KA_LLM_API_KEY required).
# Override any default explicitly by uncommenting:
KA_LLM_PROVIDER=ollama                  # ollama | openai
# KA_LLM_MODEL=
# KA_LLM_BASE_URL=
# KA_LLM_API_KEY=
# KA_LLM_TIMEOUT_SECONDS=120            # HTTP timeout for the LLM call
# KA_LLM_MAX_RETRIES=3
# KA_LLM_OUTPUT_RETRIES=2               # invalid citations/shape before typed 502

# RAG behavior
KA_CHUNK_MAX_CHARS=800
KA_CHUNK_OVERLAP_CHARS=120
KA_RETRIEVAL_TOP_K=5                    # default top_k; a request may override it
KA_RETRIEVAL_FETCH_LIMIT=20
KA_RRF_K=60
KA_MIN_RELEVANCE_SCORE=0.028
# Full-text search language (PostgreSQL text-search configuration, e.g.
# english | spanish | german | simple). Schema-bound like the embedding
# dimension: the tsv column is built for this language AT MIGRATION TIME
# (migration 0003), so changing it means re-running migrations on a fresh
# database — `KA_FTS_LANGUAGE=spanish uv run alembic upgrade head`.
# Alembic reads THIS .env file (same source of truth as the app), and the
# app verifies at startup that the database was built for the configured
# language (recorded in schema_meta by migration 0004) — a mismatch refuses
# to boot, naming both languages and the fix (ADR-0004).
# Use `simple` (no stemming, no stop words) for mixed-language corpora.
# CJK note: tsvector does not segment Chinese/Japanese/Korean — those corpora
# rely on the dense (vector) leg.
KA_FTS_LANGUAGE=english

# App
KA_DEBUG=false
KA_MAX_UPLOAD_SIZE_MB=10                # larger uploads are rejected with 413
KA_EMBEDDING_BATCH_SIZE=32              # chunks per embedding API call
# KA_API_KEY=                           # unset = auth off; set = every /api/v1/*
                                      # endpoint requires the X-API-Key header,
                                      # and /docs /redoc /openapi.json are closed
                                      # (/health always stays open)
